{
  "name": "vscode-codex-cli-launcher",
  "displayName": "Codex CLI Launcher — Run OpenAI Codex in a Side Terminal",
  "description": "Launch the OpenAI Codex AI coding agent in a side terminal from your editor toolbar — one click, fresh terminal, guided npm install. Unofficial; works in VS Code, Cursor & Windsurf on Windows, macOS & Linux.",
  "publisher": "mikesoft",
  "version": "0.1.4",
  "repository": {
    "type": "git",
    "url": "https://github.com/TheStreamCode/codex-cli-launcher.git"
  },
  "author": {
    "name": "Michael Gasperini",
    "url": "https://mikesoft.it"
  },
  "bugs": {
    "url": "https://github.com/TheStreamCode/codex-cli-launcher/issues"
  },
  "homepage": "https://mikesoft.it",
  "sponsor": {
    "url": "https://github.com/sponsors/TheStreamCode"
  },
  "license": "MIT",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#0B0F19",
    "theme": "dark"
  },
  "pricing": "Free",
  "engines": {
    "vscode": "^1.93.0"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Launching Codex CLI runs terminal commands in the current workspace. The launcher is disabled until the workspace is trusted.",
      "restrictedConfigurations": [
        "codexCliLauncher.cliCommand"
      ]
    }
  },
  "categories": [
    "AI",
    "Chat",
    "Other"
  ],
  "keywords": [
    "codex",
    "openai",
    "openai codex",
    "codex cli",
    "ai coding agent",
    "coding agent",
    "ai agent",
    "ai",
    "cli",
    "terminal",
    "launcher",
    "vscode"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codexCliLauncher.openCli",
        "title": "Open Codex CLI in Side Terminal",
        "category": "Codex CLI Launcher",
        "icon": {
          "light": "./media/launcher-mark.svg",
          "dark": "./media/launcher-mark.svg"
        }
      },
      {
        "command": "codexCliLauncher.openSettings",
        "title": "Open Settings",
        "category": "Codex CLI Launcher"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "codexCliLauncher.openCli",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Codex CLI Launcher",
      "properties": {
        "codexCliLauncher.cliCommand": {
          "type": "string",
          "scope": "machine",
          "default": "codex",
          "markdownDescription": "Command used to start Codex CLI. The default is `codex`. On Windows, quote executable paths that contain spaces, for example `\"C:\\Users\\You\\AppData\\Roaming\\npm\\codex.cmd\"`."
        },
        "codexCliLauncher.terminalName": {
          "type": "string",
          "scope": "window",
          "default": "Codex CLI",
          "description": "Base name of the terminal used by the launcher."
        },
        "codexCliLauncher.autoInstall": {
          "type": "boolean",
          "scope": "machine",
          "default": true,
          "description": "Offer to install Codex CLI automatically when the default codex command is not found. Installation only starts after explicit confirmation."
        }
      }
    }
  },
  "scripts": {
    "compile": "node ./node_modules/typescript/bin/tsc -p . --pretty false",
    "watch": "node ./node_modules/typescript/bin/tsc --watch -p . --pretty false",
    "test": "node ./node_modules/typescript/bin/tsc -p . --pretty false && node --test test/*.test.js && node ./test/integration/runTest.js",
    "test:unit": "node ./node_modules/typescript/bin/tsc -p . --pretty false && node --test test/*.test.js",
    "test:command-utils": "node ./node_modules/typescript/bin/tsc -p . --pretty false && node --test test/command-utils.test.js",
    "test:install-utils": "node ./node_modules/typescript/bin/tsc -p . --pretty false && node --test test/install-utils.test.js",
    "test:integration": "node ./node_modules/typescript/bin/tsc -p . --pretty false && node ./test/integration/runTest.js",
    "test:metadata": "node ./node_modules/typescript/bin/tsc -p . --pretty false && node --test test/metadata.test.js",
    "vscode:prepublish": "node ./node_modules/typescript/bin/tsc -p . --pretty false",
    "package": "node ./node_modules/@vscode/vsce/vsce package",
    "check": "node ./node_modules/typescript/bin/tsc -p . --pretty false && node --test test/*.test.js && node ./test/integration/runTest.js && node ./node_modules/@vscode/vsce/vsce ls",
    "generate:icon": "node ./scripts/generate-icon.js"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.93.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^6.0.3"
  }
}
